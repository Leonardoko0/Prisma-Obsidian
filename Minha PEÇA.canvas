{
	"nodes":[
		{"id":"50d6ad107f7294db","type":"text","text":"Adora explicar sobre facas","x":1870,"y":-365,"width":250,"height":60},
		{"id":"aa5eb5c86f17d3fc","type":"text","text":"Orgulhoso e meio socialmente travado","x":1870,"y":-260,"width":250,"height":60},
		{"id":"d5ad3326f435fe98","type":"text","text":"Leva o assassinato pouco a sério","x":2340,"y":-365,"width":250,"height":60},
		{"id":"84fee592cff31c19","type":"text","text":"“Mas essa lâmina… também foi mal utilizada”","x":2340,"y":-260,"width":250,"height":60},
		{"id":"67cb539bce5488a6","type":"text","text":"Colecionador","x":2160,"y":-460,"width":140,"height":50},
		{"id":"18702e686358319c","type":"text","text":"Sou um excelentíssimo pintu-... Quero dizer, pintor","x":1870,"y":15,"width":250,"height":60},
		{"id":"5003444092554db4","type":"text","text":"Todos odeiam sua arte","x":1870,"y":120,"width":250,"height":60},
		{"id":"b72daef2b5849236","type":"text","text":"Caso Sexual com a vó de Lord Tchola","x":2340,"y":15,"width":250,"height":60},
		{"id":"0ee02d100d93e84d","type":"text","text":"","x":2340,"y":120,"width":250,"height":60},
		{"id":"46ccc3bdee49c7c1","type":"text","text":"Pintor","x":2160,"y":-80,"width":140,"height":50},
		{"id":"f42d0eeab4ee0cc5","type":"text","text":"Facilmente enganado ","x":1125,"y":15,"width":250,"height":60},
		{"id":"c49568b6c10f6b48","type":"text","text":"emocionalmente afetado pelo assassinato?","x":1125,"y":120,"width":250,"height":60},
		{"id":"2367e9a3aebb216d","type":"text","text":"Compulsivamente limpo","x":1595,"y":15,"width":250,"height":60},
		{"id":"b1776d3724c1e746","type":"text","text":"\"Eu apenas limpei a tinta...\"","x":1595,"y":120,"width":250,"height":60},
		{"id":"4e8a2da1a55fadcb","type":"text","text":"Mordomo\n","x":1415,"y":-80,"width":140,"height":50},
		{"id":"1980bdf76ee9086a","type":"text","text":"Adora teorias complicadas","x":1125,"y":-365,"width":250,"height":60},
		{"id":"3704f508675a72cf","type":"text","text":"TDH","x":1595,"y":-365,"width":250,"height":60},
		{"id":"a858e8f96e96d018","type":"text","text":"Detetive","x":1415,"y":-460,"width":140,"height":50},
		{"id":"0ff52aaf56c20953","type":"text","text":"Cômicamente não inteligente","x":1595,"y":-220,"width":250,"height":60},
		{"id":"364d8735c681f6cf","type":"text","text":"“Claramente temos aqui um assassinato envolvendo… ciúmes, facas, e talvez… um cavalo?\"","x":1125,"y":-250,"width":250,"height":110},
		{"id":"2a4105806d6600b1","type":"text","text":"Área das piadas","x":1720,"y":-520,"width":250,"height":60},
