		{"id":"0d322e394069e0e6","type":"text","text":"Colecionador de faca: Sakata","x":-239,"y":-320,"width":250,"height":60,"color":"6"},
		{"id":"1a3d8d339e20f5f4","type":"text","text":"Lord Tchola(Vítima): Heitor","x":-239,"y":-150,"width":250,"height":60,"color":"6"},
		{"id":"46907788221986a7","type":"file","file":"Pasted image 20260415162431.png","x":-34,"y":-750,"width":400,"height":349,"color":"6"},
		{"id":"f69376b442f462bd","type":"text","text":"Papeis ","x":41,"y":-230,"width":250,"height":70,"color":"6"},
		{"id":"3e3ac282a71ec6b8","type":"text","text":"Cabelo","x":111,"y":-320,"width":110,"height":60,"color":"6"},
		{"id":"65352ffea1f8f467","type":"text","text":"Quadro","x":108,"y":-150,"width":117,"height":60,"color":"6"},
		{"id":"6632b6ac90cb9b2e","type":"text","text":"Detetive Gostoso: Pedrinho","x":41,"y":-30,"width":250,"height":60,"color":"6"},
		{"id":"8f1232dc37211e28","type":"text","text":"Facadas","x":-174,"y":-220,"width":120,"height":50,"color":"6"},
		{"id":"67addee33e870413","type":"text","text":"Mordomo: Lorena","x":321,"y":-320,"width":250,"height":60,"color":"6"},
		{"id":"f201d87e52d4aa48","type":"text","text":"Pintor(Assassino): Leonardo","x":321,"y":-150,"width":250,"height":60,"color":"6"},
		{"id":"a891acece3570ea6","type":"text","text":"Prisão Gostosa ","x":321,"y":90,"width":250,"height":60,"color":"6"},
		{"id":"4ccdec2d74d5fc90","type":"text","text":"## Quadro\nVai parecer que foi escrito com sangue mas na verdade foi feito com tinta.\nA vítima só queria falar que tinha tinta e foi o pintor que fez isso","x":366,"y":-575,"width":345,"height":180,"color":"6"},
		{"id":"fabd030702bd9d88","type":"text","text":"Tinta n chão","x":379,"y":-220,"width":135,"height":50,"color":"6"},
		{"id":"851a2f4d57a4f1f2","type":"text","text":"(Desculpa):*quela tinta não era minha, a minha escorre bem mais","x":539,"y":-40,"width":260,"height":80,"color":"6"},
		{"id":"c53f9aa8c607ae4e","type":"text","text":"Ele aborda o Mordomo","x":1264,"y":660,"width":250,"height":60,"color":"1"},
		{"id":"a47c5df00aebb6a8","type":"text","text":"Ele se embanana em responder as perguntas","x":1520,"y":780,"width":250,"height":60,"color":"1"},
		{"id":"1f3bc4a6447e133f","type":"text","text":"Chega o desfecho","x":2270,"y":660,"width":250,"height":60,"color":"1"},
		{"id":"fff4c811c6b0fc4b","type":"text","text":"Ele fala que o pintor pediu para que ele limpasse a sala\ncom tinta derramada","x":1520,"y":500,"width":250,"height":90,"color":"1"},
		{"id":"7c84daf55ab73e96","type":"text","text":"Ele fala que a tinta não era de qualidade e não poderia ser dele pois \"Suas tintas escorrem muito mais\"","x":2020,"y":480,"width":250,"height":110,"color":"1"},
		{"id":"4510ea082be5e663","type":"text","text":"A mancha na cena do crime não foi feita com sangue mas sim com tinta vermelha de alta qualidade","x":2020,"y":780,"width":250,"height":120,"color":"1"},
		{"id":"288c67e7d363da63","type":"text","text":" Encontra o pintor","x":1770,"y":660,"width":250,"height":60,"color":"1"},
		{"id":"cc6b9a111fd8ede2","type":"text","text":"Ele descobre que foi morto a facadas e liga isso ao colecionado","x":514,"y":505,"width":250,"height":85,"color":"1"},
		{"id":"e05189adbe488db6","type":"text","text":"Cria ideias complexas e falhas sobre o caso ","x":514,"y":780,"width":250,"height":60,"color":"1"},
		{"id":"01d18ac56c7ff05e","type":"text","text":"Ele chega no quarto do colecionador ","x":764,"y":660,"width":250,"height":60,"color":"1"},
		{"id":"ad3df4ca7084bdd7","type":"text","text":"A faca utilizada na cena do crime foi roubada","x":1014,"y":530,"width":250,"height":60,"color":"1"},
		{"id":"3f27d59d7e1e823e","type":"text","text":"Cabelo que se assemelha ao cabelo do mordomo é encontrado","x":1014,"y":780,"width":250,"height":80,"color":"1"},
		{"id":"a22e715612074727","type":"text","text":"O detetive chega na festa","x":-236,"y":660,"width":250,"height":60,"color":"1"},
		{"id":"1679295051c3df75","type":"text","text":"Ele encontra uma parcela dos personagens","x":14,"y":540,"width":250,"height":50,"color":"1"},
		{"id":"703918d2cb3e76a3","type":"text","text":"Algum personagem pode levar ele até o morto","x":14,"y":780,"width":250,"height":60,"color":"1"},
		{"id":"52e368c867a00610","type":"text","text":"Ele observa o cadaver ","x":264,"y":660,"width":250,"height":60,"color":"1"}
	],
